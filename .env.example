# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/jobz_scraper
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobz_scraper

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Scraper Configuration
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_COUNT=3
SCRAPER_DELAY=2

# Chrome/Selenium
CHROME_DRIVER_PATH=/usr/bin/chromedriver
HEADLESS_MODE=True

# Logging
LOG_LEVEL=INFO
